@model EmployeeWithDeptListViewModel
@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>
<!--/Employee/SaveEdit/1?Name=&Salary=&ImageURL=&DepartmentId=-->
<form action="/Employee/SaveEdit/@Model.Id" method="post">
   @*  <input type="hidden" name="Id" value="@Model.Id" /> *@
   <div>
       <!--Pure HTML-->
@* 
        <label>Employee Name</label>B
        <input type="text" id="EmpName" name="EmpName" value="@Model.EmpName" class="form form-control" /> *@
        <!--Pure C# HTML Helpers-->
       @*  @Html.LabelFor(e=>e.EmpName)
         @Html.TextBoxFor(e => e.EmpName, new { style = "color:red", @class="form form-control"}) 
        @Html.EditorFor(e=>e.EmpName) *@

        <!--Tag Helper-->
        <label asp-for="EmpName"></label>
        <input asp-for="EmpName" class="form form-control"/>
   </div>
    <div>
        <label>Salary</label>
        <input type="number" id="Salary" name="Salary" value="@Model.Salary" class="form form-control" />
    </div>
    <div>
        <label>Image URL</label>
        <input type="text" id="ImageURL" name="ImageURL" value="@Model.ImageURL" class="form form-control" />
    </div>
    <div>
        <label>Department</label>
        @* <input type="number" id="DepartmentId" name="DepartmentId" value="@Model.DepartmentId" class="form form-control" /> *@
        <select id="DepartmentId" name="DepartmentId" class="form form-control" >
            @foreach (var deptItem in Model.Departments)
            {
                if (Model.DepartmentId == deptItem.Id)
                {
                    <option value="@deptItem.Id" selected>@deptItem.Name
                    </option>
                }
                else
                {
                    <option value="@deptItem.Id">@deptItem.Name
                    </option>
                }
            }

        </select>
    </div>
   <input type="submit" value="Save" class="btn btn-success"/>
</form>

<br />
<a href="/Employee/Index">Back To List</a>
@Html.ActionLink("Back To List","Index","Employee",null,new{@class="btn btn-success"})
<a asp-action="Index" asp-controller="Employee">Back To List</a>
<hr />
<a href="/Employee/details/@Model.Id?name=@Model.EmpName">d-etails</a>
@Html.ActionLink("- details -","details","Employee",new{id=Model.Id,name=Model.EmpName})
<a asp-action="details" asp-controller="Employee" asp-route-id="@Model.Id" asp-route-name="@Model.EmpName">details</a>


